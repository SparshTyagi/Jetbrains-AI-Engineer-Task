{
  "name": "research_failures_specialist",
  "version": "1.0",
  "tools": [
    {
      "name": "corpus_search",
      "enabled": true,
      "retries": 2,
      "timeout_ms": 3000
    },
    {
      "name": "citation_verifier",
      "enabled": true,
      "retries": 0,
      "timeout_ms": 3000
    },
    {
      "name": "note_memory",
      "enabled": true,
      "retries": 0,
      "timeout_ms": 3000
    }
  ],
  "memory": {
    "enabled": true,
    "source_grounded": true,
    "max_notes": 8,
    "decay_policy": "latest_verified"
  },
  "retrieval": {
    "strategy": "keyword",
    "top_k": 6,
    "source_diversity": true,
    "max_per_source": 3,
    "query_expansion": true,
    "citation_verification": true,
    "min_score": 0.0
  },
  "planner": {
    "style": "evidence_first",
    "steps": [
      "expand_domain_query",
      "retrieve_diverse_sources",
      "write_grounded_notes",
      "verify_citations",
      "check_contradictions",
      "synthesize"
    ],
    "contradiction_check": true,
    "evidence_first": true
  },
  "eval_metrics": [
    "citation_precision",
    "evidence_recall",
    "unsupported_claim_rate",
    "contradiction_handling",
    "rubric_score",
    "tool_failure_recovery"
  ],
  "frozen": true,
  "notes": [
    "evidence-first planning",
    "source diversity for noisy retrieval",
    "citation verification for unsupported claims",
    "bounded source-grounded memory",
    "tool retries with typed failures",
    "schema validation rollback",
    "freeze architecture after validation stability",
    "evaluation mismatch between fluency and evidence support",
    "llm-mined lessons: evidence-first planning, citation verification, source diversity, query expansion, source-grounded memory, tool retries, typed tool failures, schema validation"
  ]
}
